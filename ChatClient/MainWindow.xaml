<Window x:Class="ChatClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ChatClient"
        Title="Antigravity Copilot" Height="800" Width="1200"
        Background="#202020"
        FontFamily="Segoe UI Variable, Segoe UI, Roboto, Helvetica, Arial, sans-serif"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Fluent Design Colors -->
        <SolidColorBrush x:Key="BgRoot" Color="#202020"/>
        <SolidColorBrush x:Key="BgSidebar" Color="#18181A"/>
        <SolidColorBrush x:Key="BgInput" Color="#2D2D30"/>
        <SolidColorBrush x:Key="BgCard" Color="#28282B"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="TextMuted" Color="#9E9E9E"/>
        <SolidColorBrush x:Key="AccentColor" Color="#4CC2FF"/>
        <SolidColorBrush x:Key="AccentHover" Color="#60CDFF"/>
        <SolidColorBrush x:Key="Divider" Color="#2D2D2D"/>

        <!-- ScrollViewer Style for modern thin scrollbars -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Background="#404040" />
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Button -->
        <Style TargetType="Button" x:Key="FluentButton">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon Button -->
        <Style TargetType="Button" x:Key="IconButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#10FFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Fluent TextBox -->
        <Style TargetType="TextBox" x:Key="FluentTextBox">
            <Setter Property="Background" Value="#11FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4,4,0,0">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource BgSidebar}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Sidebar Header -->
                <StackPanel Grid.Row="0" Margin="20,25,20,10">
                    <TextBlock Text="SERVER DETAILS" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtServerIP" Style="{StaticResource FluentTextBox}" Text="127.0.0.1" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="YOUR IDENTIFIER" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="11" Margin="0,10,0,8"/>
                    <TextBox x:Name="txtUsername" Style="{StaticResource FluentTextBox}" Text="Developer" Margin="0,0,0,15"/>
                    
                    <Button x:Name="btnConnect" Content="Connect" Style="{StaticResource FluentButton}" Click="btnConnect_Click" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Profile Area -->
                <Border Grid.Row="2" Background="{StaticResource BgInput}" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="profileAvatar" Width="40" Height="40" CornerRadius="20" Background="{StaticResource AccentColor}" Cursor="Hand" MouseLeftButtonDown="profileAvatar_MouseLeftButtonDown" ToolTip="Change Avatar">
                            <Grid>
                                <TextBlock x:Name="lblAvatarInitials" Text="D" Foreground="#202020" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                                <Ellipse x:Name="imgProfileAvatar" Width="40" Height="40" Visibility="Hidden">
                                    <Ellipse.Fill>
                                        <ImageBrush x:Name="brushProfileAvatar" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock x:Name="lblProfileName" Text="Offline" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock x:Name="lblProfileStatus" Text="Not Connected" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CHAT AREA -->
        <Grid Grid.Column="1" Background="{StaticResource BgRoot}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- MVVM Chat History -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                <ItemsControl x:Name="chatItemsControl" ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="15"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Y" To="0" Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    
                    <ItemsControl.Resources>
                        <!-- SYSTEM MESSAGE -->
                        <DataTemplate DataType="{x:Type local:SystemMessageViewModel}">
                            <Border Background="#1AFFFFFF" CornerRadius="6" Padding="12,6" Margin="10,8" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Text}" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                            </Border>
                        </DataTemplate>
                        
                        <!-- TEXT MESSAGE -->
                        <DataTemplate DataType="{x:Type local:TextMessageViewModel}">
                            <Grid Margin="{Binding Margin}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Avatar on left -->
                                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="21" Background="{Binding AvatarColor}" VerticalAlignment="Top" Visibility="{Binding AvatarVisibility}">
                                    <Grid>
                                        <TextBlock Text="{Binding Initials}" Foreground="#202020" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding AvatarInitialsVisibility}"/>
                                        <Ellipse Width="42" Height="42" Visibility="{Binding AvatarImageVisibility}">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding AvatarImage}" Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </Grid>
                                </Border>
                                
                                <StackPanel Grid.Column="1" HorizontalAlignment="{Binding Alignment}" MaxWidth="600">
                                    <StackPanel Orientation="Horizontal" Visibility="{Binding HeaderVisibility}" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Sender}" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{Binding Time}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="10,2,0,0"/>
                                    </StackPanel>
                                    <Border Background="{Binding MessageBackground}" CornerRadius="{Binding BubbleRadius}" Padding="12,8">
                                        <TextBlock Text="{Binding Text}" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" FontSize="15" LineHeight="20"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>

                        <!-- FILE MESSAGE -->
                        <DataTemplate DataType="{x:Type local:FileMessageViewModel}">
                            <Border Background="{Binding MessageBackground}" CornerRadius="8" Padding="16" Margin="{Binding Margin}" HorizontalAlignment="{Binding Alignment}" MaxWidth="450" BorderBrush="#1AFFFFFF" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="4" Opacity="0.15" Direction="270"/>
                                </Border.Effect>
                                <StackPanel>
                                    
                                    <Border Visibility="{Binding ImageVisibility}" CornerRadius="6" Margin="0,0,0,10" ClipToBounds="True">
                                        <Image Source="{Binding ImageContent}" Stretch="Uniform" MaxHeight="300" MaxWidth="400"/>
                                    </Border>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                            <TextBlock Text="{Binding FileName}" Foreground="{StaticResource AccentColor}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding FileSizeStr}" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{Binding StatusColor}" FontSize="12"/>
                                            <Button Content="Download" Command="{Binding DownloadCommand}" IsEnabled="{Binding CanDownload}" Style="{StaticResource FluentButton}" Padding="15,6"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.Resources>
                </ItemsControl>
            </ScrollViewer>

            <!-- INPUT AREA -->
            <Border Grid.Row="1" Background="{StaticResource BgRoot}" Padding="20">
                <Grid>
                    <Popup x:Name="emojiPopup" StaysOpen="False" PlacementTarget="{Binding ElementName=btnEmoji}" Placement="Top" VerticalOffset="-10" HorizontalOffset="-280" PopupAnimation="Fade" AllowsTransparency="True">
                        <Border Background="{StaticResource BgCard}" BorderBrush="#66FFFFFF" BorderThickness="1" CornerRadius="8" Width="320" Height="250" Padding="10">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="5" Opacity="0.5"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Emojis" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" Margin="5,0,0,10"/>
                                
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ListBox x:Name="emojiList" ItemsSource="{Binding Emojis}" 
                                             Background="Transparent" BorderThickness="0" 
                                             SelectionChanged="EmojiList_SelectionChanged"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Foreground="White" FontFamily="Segoe UI Emoji" FontSize="24" Cursor="Hand" HorizontalAlignment="Center" Margin="6"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Margin="2">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#2AFFFFFF"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#40FFFFFF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Popup>

                    <Border Background="{StaticResource BgInput}" CornerRadius="12" Padding="6" BorderBrush="#1AFFFFFF" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="4,0,8,0">
                                <Button Content="📎" Width="36" Height="36" Style="{StaticResource IconButton}" ToolTip="Attach File" IsEnabled="{Binding ElementName=btnSend, Path=IsEnabled}" Click="btnAttach_Click"/>
                                <Button Content="📁" Width="36" Height="36" Style="{StaticResource IconButton}" ToolTip="Attach Folder" IsEnabled="{Binding ElementName=btnSend, Path=IsEnabled}" Click="btnAttachFolder_Click"/>
                            </StackPanel>

                            <TextBox x:Name="txtMessage" Grid.Column="1"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextPrimary}"
                                     BorderThickness="0"
                                     FontSize="15"
                                     Padding="4,8"
                                     CaretBrush="{StaticResource AccentColor}"
                                     VerticalContentAlignment="Center" 
                                     IsEnabled="False" 
                                     KeyDown="txtMessage_KeyDown"/>

                            <Button x:Name="btnEmoji" Grid.Column="2" Content="😀" Width="36" Height="36" Margin="4,0,4,0" Style="{StaticResource IconButton}" ToolTip="Emojis" IsEnabled="{Binding ElementName=btnSend, Path=IsEnabled}" Click="btnEmoji_Click"/>
                            <Button x:Name="btnSend" Grid.Column="3" Content="➤" Width="40" Height="40" Margin="4,0,4,0" Style="{StaticResource IconButton}" Foreground="{StaticResource AccentColor}" IsEnabled="False" Click="btnSend_Click" IsDefault="True"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
